# direnv config — auto-loads secrets from K8s cluster cuando entras al repo.
#
# Setup global (una vez por Mac):
#   brew install direnv
#   echo 'eval "$(direnv hook zsh)"' >> ~/.zshrc && exec zsh
#   bash <(curl -s https://raw.githubusercontent.com/Johanson1988/remix-pod-starter/main/scripts/setup-direnv-helper.sh)
#
# Per-repo:
#   ssh -fN coruscant     # túnel SSH activo
#   direnv allow          # primera vez

use_kube_secret bots devops-agent-secrets
